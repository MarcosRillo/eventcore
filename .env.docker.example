# Docker Environment Variables - TEMPLATE
# Copy this file to .env.docker and fill with your actual credentials
# NEVER commit .env.docker to git!

# PostgreSQL Container Config
POSTGRES_DB=plataforma_calendario
POSTGRES_USER=plataforma_user
POSTGRES_PASSWORD=your_secure_password_here

# Laravel Backend Config (DB_PASSWORD must match POSTGRES_PASSWORD)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=plataforma_calendario
DB_USERNAME=plataforma_user
DB_PASSWORD=your_secure_password_here
