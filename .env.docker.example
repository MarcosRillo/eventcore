# Docker Environment Variables - TEMPLATE
# Copy this file to .env.docker and fill with your actual credentials
# NEVER commit .env.docker to git!

# Database Configuration
POSTGRES_DB=plataforma_calendario
POSTGRES_USER=your_db_user_here
POSTGRES_PASSWORD=your_secure_password_here

# Database Connection Settings
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432

# Instructions:
# 1. Copy this file: cp .env.docker.example .env.docker
# 2. Generate a secure password: openssl rand -base64 32
# 3. Replace 'your_db_user_here' with your desired username
# 4. Replace 'your_secure_password_here' with the generated password
# 5. Never commit .env.docker to git!
