# ─────────────────────────────────────────────────────────────
#  eventcore — variables de entorno
#  Copiar a .env y completar. NO commitear .env nunca.
#  Cada secret debería ser único por entorno (dev/staging/prod).
# ─────────────────────────────────────────────────────────────

# ───────── App (Laravel) ─────────
APP_NAME=eventcore
APP_ENV=local                       # local | staging | production
APP_KEY=                            # generar con: php artisan key:generate
APP_DEBUG=true                      # poner false en producción
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Argentina/Buenos_Aires
APP_LOCALE=es

# ───────── Database (PostgreSQL) ─────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=eventcore
DB_USERNAME=eventcore
DB_PASSWORD=                        # password del usuario de DB

# ───────── Cache / Queue / Sessions ─────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true          # true en producción (requiere HTTPS)
SESSION_SAME_SITE=lax

# ───────── Redis ─────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=                     # vacío en local; obligatorio en prod

# ───────── Broadcasting (Reverb) ─────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=                      # generar con: php artisan reverb:install
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http                  # https en producción

# ───────── Mail ─────────
MAIL_MAILER=log                     # log | smtp | resend | postmark | ses
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@eventcore.dev
MAIL_FROM_NAME="${APP_NAME}"

# ───────── Sanctum ─────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000

# ───────── Storage (filesystems) ─────────
FILESYSTEM_DISK=local               # local | public | s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ───────── Logging ─────────
LOG_CHANNEL=stack
LOG_LEVEL=debug                     # info | warning | error en prod

# ─────────────────────────────────────────────────────────────
#  Frontend (Next.js — apps/web/.env.local)
#  Estas se consumen del lado cliente: NUNCA poner secrets acá.
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Reverb (cliente)
NEXT_PUBLIC_REVERB_APP_KEY=
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=http

# ───────── Seeders ─────────
SEED_DEMO_PASSWORD=demo1234         # password de seeders, sólo demo
