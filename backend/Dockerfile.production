# ============================================================
# Stage 1: Composer dependencies (isolated, cached layer)
# ============================================================
FROM composer:2.8 AS vendor

WORKDIR /app

# Install dependencies first (cached unless lock changes)
COPY composer.json composer.lock ./
RUN composer install \
    --no-dev \
    --no-interaction \
    --no-scripts \
    --no-autoloader \
    --prefer-dist

# Copy full source for autoload generation
COPY . .
RUN composer dump-autoload --optimize --classmap-authoritative

# ============================================================
# Stage 2: Production image with FrankenPHP
# ============================================================
FROM dunglas/frankenphp:1-php8.3@sha256:d43dc97b4c2eaf6dbaad4ae3ed42e379a75b9db8e2f09ab29b014a264c71a3a3 AS production

# --- PHP extensions (matching existing Dockerfile) ---
RUN install-php-extensions \
    pdo_pgsql \
    mbstring \
    zip \
    gd \
    exif \
    pcntl \
    bcmath \
    opcache \
    redis

# --- PHP production settings ---
RUN mv "$PHP_INI_DIR/php.ini-production" "$PHP_INI_DIR/php.ini"

RUN { \
    echo 'memory_limit = 512M'; \
    echo 'upload_max_filesize = 64M'; \
    echo 'post_max_size = 64M'; \
    echo 'opcache.enable = 1'; \
    echo 'opcache.memory_consumption = 256'; \
    echo 'opcache.interned_strings_buffer = 16'; \
    echo 'opcache.max_accelerated_files = 10000'; \
    echo 'opcache.validate_timestamps = 0'; \
    echo 'expose_php = Off'; \
    } > "$PHP_INI_DIR/conf.d/app.ini"

# --- Non-root user ---
ARG USER=www
RUN useradd --create-home ${USER} && \
    setcap -r /usr/local/bin/frankenphp && \
    chown -R ${USER}:${USER} /data/caddy /config/caddy

# --- Server config ---
# SERVER_NAME is set dynamically at runtime by docker-entrypoint.sh
# to respect the PORT env var assigned by cloud providers (Render, Railway, etc.)
# Falls back to :80 for local Docker usage

WORKDIR /app

# --- Copy vendor from stage 1 ---
COPY --from=vendor --chown=${USER}:${USER} /app/vendor ./vendor

# --- Copy application source ---
COPY --chown=${USER}:${USER} . .

# --- Laravel requirements ---
RUN touch .env && \
    chown -R ${USER}:${USER} storage bootstrap/cache && \
    chmod -R 775 storage bootstrap/cache

# --- Startup script ---
# 1. storage:link (idempotent symlink)
# 2. optimize (cache config/routes/views with runtime env vars)
# 3. exec into FrankenPHP
# Note: migrations run via preDeployCommand in render.yaml before container starts
RUN printf '#!/bin/sh\nset -e\nexport SERVER_NAME=":${PORT:-80}"\nphp artisan storage:link 2>/dev/null || true\nphp artisan optimize --force 2>/dev/null || true\nexec "$@"\n' \
    > /usr/local/bin/docker-entrypoint.sh && chmod +x /usr/local/bin/docker-entrypoint.sh

USER ${USER}

EXPOSE 80

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["frankenphp", "run", "--config", "/etc/caddy/Caddyfile"]
